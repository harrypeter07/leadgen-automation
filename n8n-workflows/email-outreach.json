        "url": "={{ $env.SUPABASE_URL.replace(/\\/+$/, '') }}/rest/v1/leads?id=eq.{{ $('Fetch Lead Send Details').item.json.id }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
