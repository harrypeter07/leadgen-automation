    },
    {
      "parameters": {
        "options": {}
      },
      "id": "e1f2a3b4-0003-4000-8000-000000000003",
      "name": "Loop Lead IDs",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [460, 200]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL.replace(/\\/+$/, '') }}/rest/v1/leads?id=eq.{{ $json.id }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" }
          ]
        },
        "options": {}
      },
      "id": "e1f2a3b4-0004-4000-8000-000000000004",
      "name": "Fetch Lead Details",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [660, 200]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const lead = $input.first().json;\nconst enrichment = lead.enrichment_fields || {};\nconst description = enrichment.business_description || lead.notes || 'local business';\nconst offerings = (enrichment.key_offerings || []).join(', ') || lead.category || 'services';\nconst contactName = enrichment.contact_person || '';\nconst contactTitle = enrichment.contact_position || '';\n\nconst salutation = contactName ? `Hi ${contactName.split(' ')[0]}` : 'Hi there';\n\nconst prompt = `You are a professional outreach writer. Write a simple, conversational email to a business owner.\\nIt MUST sound like it was hand-written by a real person, not a marketing team or AI template.\\n\\nRules:\\n1. Short paragraphs (2 to 3 lines maximum).\\n2. Avoid ALL tech jargon & hype words (API, SMTP, OAuth, Port 465, infrastructure, verified SMTP, webhook, integration, pipeline, synergy, optimize, guaranteed, boost, revolutionary).\\n3. Do not use centered layout phrasing, centered titles, hero sections, bold text, or multiple call-to-actions.\\n4. Keep the reading level simple (8th grade English), friendly, and direct.\\n\\nDetails:\\n- Business Name: ${lead.name}\\n- Category/Industry: ${lead.category || 'business'}\\n- What they do: ${description}\\n- Main offerings: ${offerings}\\n\\nOur pitch:\\nWe build clean, modern design mockups for local businesses to show what a high-converting homepage can look like. We share these mockups completely free, with no obligations.\\n\\nGenerate exactly this JSON and nothing else (no markdown blocks, raw JSON only):\\n{\\n  \\\"email_subject\\\": \\\"A natural, conversational subject line under 50 characters, no exclamation marks or emojis (e.g. 'quick homepage idea for ${lead.name}')\\\",\\n  \\\"email_body\\\": \\\"Write a 3-paragraph outreach message. Paragraph 1: Start with '${salutation},' and mention a specific offering or detail of theirs. Paragraph 2: Mention that we created a free custom homepage mockup for their business, with no strings attached, just to show what is possible. Paragraph 3: Ask a soft question (e.g. 'Would you be open to taking a quick look at it?'). Sign off with: 'Best regards,\\\\\nZarss Outreach Team'\\\"\\n}`;\n\\nreturn [{ json: { id: lead.id, prompt } }];"
      },
      "id": "e1f2a3b4-0005-4000-8000-000000000005",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [860, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key={{ $env.GEMINI_API_KEY }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [{\"parts\": [{\"text\": {{ JSON.stringify($json.prompt) }}}]}],\n  \"generationConfig\": {\n    \"temperature\": 0.6,\n    \"maxOutputTokens\": 8192,\n    \"responseMimeType\": \"application/json\"\n  }\n}",
        "options": {}
      },
      "id": "e1f2a3b4-0006-4000-8000-000000000006",
      "name": "Call Gemini AI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1060, 200]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const gemini = $json;\nconst text = gemini.candidates[0].content.parts[0].text;\n\nlet parsed;\ntry {\n  parsed = JSON.parse(text);\n} catch (e) {\n  const match = text.match(/\\{[\\s\\S]*\\}/);\n  if (match) {\n    try { parsed = JSON.parse(match[0]); } catch (_) { parsed = {}; }\n  } else {\n    parsed = {};\n  }\n}\n\nconst id = $('Build Prompt').item.json.id;\n\nreturn [{\n  json: {\n    id,\n    subject: parsed.email_subject || 'Quick question relative to website',\n    body: parsed.email_body || ''\n  }\n}];"
      },
      "id": "e1f2a3b4-0007-4000-8000-000000000007",
      "name": "Parse AI Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1260, 200]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL.replace(/\\/+$/, '') }}/rest/v1/leads?id=eq.{{ $json.id }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"ai_message_email_subject\": {{ JSON.stringify($json.subject) }},\n  \"ai_message_email_body\": {{ JSON.stringify($json.body) }},\n  \"status\": \"new\"\n}",
        "options": {}
      },
