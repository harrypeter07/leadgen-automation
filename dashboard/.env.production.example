# Production environment variables for Vercel deployment
#
# Add these in the Vercel dashboard:
#   Project → Settings → Environment Variables → Add each variable below
#
# Apply to: Production (and Preview if you want staging to work)

# Supabase project URL (public — safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase anon key (public — read-only due to RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Supabase service role key (SECRET — server-side only, never expose to browser)
# Used by Server Components and API routes for full read/write access
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# ── How to find Supabase values ──
# 1. Go to https://app.supabase.com
# 2. Open your project → Settings → API
# 3. Copy Project URL → NEXT_PUBLIC_SUPABASE_URL
# 4. Copy anon public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# 5. Copy service_role secret key → SUPABASE_SERVICE_ROLE_KEY
#
# ── Vercel deployment steps ──
# 1. Push dashboard/ to GitHub
# 2. Go to https://vercel.com → Add New Project → Import your repo
# 3. Set Root Directory to "dashboard"
# 4. Add all three env vars above in Settings → Environment Variables
# 5. Deploy — Vercel auto-detects Next.js via vercel.json
#
# Note: RESEND_API_KEY is NOT needed in the dashboard — email sending
# is handled by n8n, not the Next.js frontend.

# TinyFish API Key (SECRET — server-side only, never expose to browser)
# Get a key at https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=sk-tinyfish-0YxHuvbi-dw9Hfh7ynR7mRI9HixoEoQS
